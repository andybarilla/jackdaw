{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "sourceMap": true,
    "declaration": false,
    "types": ["node"]
  },
  "include": ["src/desktop/**/*.ts", "src/service/**/*.ts", "src/shared/**/*.ts"]
}
