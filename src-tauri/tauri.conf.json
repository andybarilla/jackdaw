{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jackdaw",
  "version": "0.1.9",
  "identifier": "com.jackdaw.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Jackdaw",
        "width": 400,
        "height": 600,
        "visible": false,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI4RTIxRDJEMjYzRjk0QjEKUldTeGxEOG1MUjNpS0NnS2RFTDR1ZDFLOWZMRWFzVnR1eVFHK3V4NlVldXJzaTE2L1E1SmlleHIK",
      "endpoints": [
        "https://github.com/andybarilla/jackdaw/releases/latest/download/latest.json"
      ]
    }
  }
}
